## 编码规范

### Handler 创建规范

所有 Handler 必须遵循此模板：

```typescript
import { IMessageHandler, IWebviewMessenger } from '../../shared-interfaces';
import { IPanelContextProvider } from '../interfaces';
import { ILogger } from '@http-forge/core';

/**
 * Handles [message type] messages
 * 
 * Single Responsibility: Only routes and dispatches [specific message]
 * Dependency Inversion: Depends on ICommand abstraction
 */
export class MyHandler implements IMessageHandler {
  constructor(
    private myCommand: IMyCommand,                    // ✅ Command 接口
    private contextProvider: IPanelContextProvider,   // ✅ Context 接口
    private logger: ILogger                           // ✅ Logger 接口
  ) {}

  getSupportedCommands(): string[] {
    return ['myCommand'];
  }

  async handle(
    command: string,
    message: any,
    messenger: IWebviewMessenger
  ): Promise<boolean> {
    if (command !== 'myCommand') {
      return false;
    }

    try {
      // 1. 验证输入
      this.validateInput(message);

      // 2. 执行 Command
      const result = await this.myCommand.execute({
        data: message.data,
        context: this.contextProvider.getCurrentContext()
      });

      // 3. 发送成功消息
      messenger.postMessage({
        type: 'myCommandSuccess',
        data: result
      });

      return true;
    } catch (error) {
      this.logger.error('[MyHandler] Execution failed', error);
      messenger.postMessage({
        type: 'myCommandError',
        error: (error as Error).message
      });
      return false;
    }
  }

  private validateInput(message: any): void {
    if (!message.data) {
      throw new Error('Missing required field: data');
    }
  }
}
```

**检查清单**:
- [ ] 实现 IMessageHandler 接口
- [ ] 构造函数参数都是接口（不是具体类）
- [ ] getSupportedCommands() 返回字符串数组
- [ ] handle() 使用 try-catch 处理错误
- [ ] 调用 this.myCommand.execute()（不是 getServiceContainer()）
- [ ] 没有 as any 类型转换
- [ ] logger 用于错误日志

