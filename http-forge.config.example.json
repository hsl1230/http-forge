{
  "version": "1.0",
  "storage": {
    "format": "folder",
    "root": "./http-forge",
    "history": "./.http-forge-cache/histories",
    "results": "./.http-forge-cache/results"
  },
  "request": {
    "timeout": 30000,
    "followRedirects": true,
    "maxRedirects": 10,
    "strictSSL": true
  },
  "scripts": {
    "modulePaths": ["./src", "./lib"]
  },
  "runner": {
    "resultsRetentionDays": 7,
    "indexPageSize": 1000,
    "recentErrorsLimit": 20
  },
  "environments": {
    "default": "dev"
  },
  "proxy": null,
  "secrets": {
    "providers": {
      "aws": {
        "provider": "aws",
        "region": "us-east-1"
      },
      "azure": {
        "provider": "azure",
        "vaultUrl": "https://my-vault.vault.azure.net"
      },
      "vault": {
        "provider": "vault",
        "address": "https://vault.corp.com",
        "mountPath": "secret",
        "namespace": "admin"
      },
      "op": {
        "provider": "1password",
        "vault": "Private"
      },
      "gcp": {
        "provider": "gcp",
        "projectId": "my-project-123"
      },
      "doppler": {
        "provider": "doppler"
      }
    }
  }
}
