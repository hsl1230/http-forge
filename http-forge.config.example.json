{
  "version": "1.0",
  "storage": {
    "format": "folder",
    "root": "./http-forge",
    "history": "./.http-forge-cache/histories",
    "results": "./.http-forge-cache/results"
  },
  "request": {
    "timeout": 30000,
    "followRedirects": true,
    "maxRedirects": 10,
    "strictSSL": true,
    "tls": {
      "caPath": "./certs/ca.pem"
    },
    "certificates": [
      {
        "host": "api.internal.example.com",
        "certPath": "./certs/client-cert.pem",
        "keyPath": "./certs/client-key.pem",
        "passphrase": "",
        "enabled": true
      },
      {
        "host": "*.corp.example.com",
        "pfxPath": "./certs/client.p12",
        "passphrase": "",
        "enabled": true
      }
    ]
  },
  "scripts": {
    "modulePaths": ["./src", "./lib"],
    "scope": "shared",
    "timeout": 5000
  },
  "runner": {
    "resultsRetentionDays": 7,
    "indexPageSize": 1000,
    "recentErrorsLimit": 20,
    "report": {
      "maxBodyChars": 100000,
      "embedBodies": "failed"
    }
  },
  "environments": {
    "default": "dev"
  },
  "mcp": {
    "toolPrefix": "",
    "excludedCollections": [],
    "excludedSuites": [],
    "maxRequestsPerCall": 50,
    "toolMode": "flat",
    "drilldownThreshold": 200,
    "cors": {
      "allowedOrigins": ["http://localhost", "http://127.0.0.1"]
    }
  },
  "proxy": {
    "enabled": true,
    "http": "http://proxy.corp.com:8080",
    "https": "http://proxy.corp.com:8080",
    "bypass": ["localhost", "127.0.0.1", "*.internal.corp.com"]
  },
  "secrets": {
    "providers": {
      "aws": {
        "provider": "aws",
        "region": "us-east-1"
      },
      "azure": {
        "provider": "azure",
        "vaultUrl": "https://my-vault.vault.azure.net"
      },
      "vault": {
        "provider": "vault",
        "address": "https://vault.corp.com",
        "mountPath": "secret",
        "namespace": "admin"
      },
      "op": {
        "provider": "1password",
        "vault": "Private"
      },
      "gcp": {
        "provider": "gcp",
        "projectId": "my-project-123"
      },
      "doppler": {
        "provider": "doppler"
      }
    }
  }
}
