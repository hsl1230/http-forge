{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HTTP Forge Body Schema",
  "description": "Defines the request body schema for OpenAPI generation. Stored as body.schema.json alongside body.json.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for validation"
    },
    "contentType": {
      "type": "string",
      "description": "Primary MIME type shorthand (e.g., 'application/json'). Used when 'content' map is absent."
    },
    "schema": {
      "type": "object",
      "description": "JSON Schema for the request body (primary / shorthand)"
    },
    "components": {
      "type": "object",
      "description": "Reusable schema components (local $ref targets)",
      "additionalProperties": {
        "type": "object"
      }
    },
    "content": {
      "type": "object",
      "description": "Multiple content types (mirrors OpenAPI content map). Takes precedence over shorthand contentType/schema.",
      "additionalProperties": {
        "$ref": "#/definitions/contentDefinition"
      }
    },
    "encoding": {
      "type": "object",
      "description": "Encoding metadata per property (for multipart/form-data and x-www-form-urlencoded)",
      "additionalProperties": {
        "$ref": "#/definitions/encodingDefinition"
      }
    }
  },
  "required": ["schema"],
  "definitions": {
    "contentDefinition": {
      "type": "object",
      "properties": {
        "schema": {
          "type": "object",
          "description": "JSON Schema for this content type"
        },
        "examples": {
          "type": "object",
          "description": "Named examples",
          "additionalProperties": {
            "$ref": "#/definitions/example"
          }
        },
        "encoding": {
          "type": "object",
          "description": "Encoding metadata per property",
          "additionalProperties": {
            "$ref": "#/definitions/encodingDefinition"
          }
        }
      }
    },
    "example": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string",
          "description": "Short description of the example"
        },
        "value": {
          "description": "Example value (any JSON)"
        }
      }
    },
    "encodingDefinition": {
      "type": "object",
      "properties": {
        "contentType": {
          "type": "string",
          "description": "Content type for the property"
        },
        "style": {
          "type": "string",
          "enum": ["form", "spaceDelimited", "pipeDelimited", "deepObject"],
          "description": "Serialization style"
        },
        "explode": {
          "type": "boolean",
          "description": "Whether arrays/objects generate separate parameters"
        },
        "allowReserved": {
          "type": "boolean",
          "description": "Allow reserved characters in values"
        },
        "headers": {
          "type": "object",
          "description": "Additional headers for the part",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "schema": { "type": "object" }
            }
          }
        }
      }
    }
  }
}
